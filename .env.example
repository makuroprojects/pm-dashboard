# Database
DATABASE_URL=postgresql://user:password@localhost:5432/base-template
DIRECT_URL=postgresql://user:password@localhost:5432/base-template

# Dev Inspector
REACT_EDITOR=code
PORT=3000

# Redis
REDIS_URL=redis://localhost:6379

# Claude Code Telegram Notification
TELEGRAM_NOTIFY_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SUPER_ADMIN_EMAIL=admin@example.com

MCP_SECRET=

# pm-watch webhook (ActivityWatch ingestion)
# Set to a long random string — every pmw agent uses this as its Bearer token.
PMW_WEBHOOK_TOKEN=
PMW_EVENT_BATCH_MAX=500

# GitHub webhook (per-project repo activity)
# Shared HMAC secret — paste into each repo's webhook setting.
# Endpoint: POST /webhooks/github, content-type application/json.
GITHUB_WEBHOOK_SECRET=
